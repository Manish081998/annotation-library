{
  "name": "annotation-library-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:renderer && npm run build:angular",
    "build:core": "npm run build --workspace=packages/annot-core",
    "build:renderer": "npm run build --workspace=packages/annot-renderer",
    "build:angular": "npm run build --workspace=packages/annot-angular",
    "test": "npm run test --workspaces --if-present",
    "test:core": "npm run test --workspace=packages/annot-core",
    "lint": "eslint 'packages/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "demo": "npm run start --workspace=apps/demo",
    "demo:build": "npm run build --workspace=apps/demo",
    "publish:all": "npm run build && npm publish --workspace=packages/annot-core && npm publish --workspace=packages/annot-renderer && npm publish --workspace=packages/annot-angular"
  },
  "devDependencies": {
    "@angular/compiler": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ng-packagr": "^17.0.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.4.0"
  }
}
